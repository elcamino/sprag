# Demonstration Caddy config for Sprag.
#
# Set SPRAG_DOMAIN to your real domain to get automatic HTTPS from Caddy.
# It defaults to localhost for local testing (Caddy issues a local CA cert).
#
# Caddy v2 imposes no default request-body cap, so 5 GB uploads pass straight
# through; the size limit is enforced inside Sprag via MAX_FILE_SIZE.
#
# Caddy appends the real client address to X-Forwarded-For. Sprag is configured
# with TRUSTED_PROXY_HOPS=1 so it reads exactly that appended entry and ignores
# any value a client tries to spoof on the left.
{$SPRAG_DOMAIN:localhost} {
	reverse_proxy sprag-app:8080
}
